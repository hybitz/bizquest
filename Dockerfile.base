FROM rust:1.95-alpine

RUN apk add --no-cache musl-dev nodejs yarn

WORKDIR /app

# Rust の依存クレートを先にビルドしてレイヤーキャッシュを効かせる
ADD Cargo.toml Cargo.lock ./
RUN mkdir src && echo 'fn main() {}' > src/main.rs && \
    cargo build --release && \
    rm -rf src target/release/bizquest target/release/deps/bizquest*

ADD package.json yarn.lock ./
RUN yarn install && yarn cache clean
